---
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MOBILE EDITOR - FRAMEWORK FILE
//
// This page hosts the Loomwork Mobile editor.
// Do NOT edit in site repos - changes come from loomwork.
//
// Currently disabled while security hardening is in progress.
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
import { SITE } from "../../site.config";
// import MobileApp from "../../components/mobile/MobileApp";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1c1917" />
    <title>Edit - {SITE.name}</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        color: #1c1917;
        background: #fafaf9;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .maintenance {
        text-align: center;
        padding: 2rem;
        max-width: 28rem;
      }
      .maintenance__icon { font-size: 3rem; margin-bottom: 1rem; }
      .maintenance__title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
      .maintenance__text { color: #78716c; font-size: 0.875rem; }
    </style>
  </head>
  <body>
    <div class="maintenance">
      <div class="maintenance__icon">⬡</div>
      <h1 class="maintenance__title">{SITE.name} Mobile Editor</h1>
      <p class="maintenance__text">
        The mobile editor is temporarily disabled while security improvements are being completed.
        It will be back soon.
      </p>
    </div>
  </body>
</html>
